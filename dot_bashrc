# Quinlan Git Bash profile (Windows native)
# Managed by chezmoi. Do not edit ~/.bashrc directly.

export CLAUDE_CODE_GIT_BASH_PATH='C:\Program Files\Git\bin\bash.exe'

_QUINLAN_MODULE_ROOT="$HOME/.config/quinlan-shell/modules"
_QUINLAN_USER_FILE="$HOME/.quinlan-user"

_quinlan_source_module() {
    local module_name="$1"
    local module_path="${_QUINLAN_MODULE_ROOT}/${module_name}"

    if [[ ! -f "$module_path" ]]; then
        echo "[quinlan-shell] Missing module: $module_path" >&2
        return 1
    fi

    # shellcheck source=/dev/null
    source "$module_path"
}

if [[ ! -d "$_QUINLAN_MODULE_ROOT" ]]; then
    echo "[quinlan-shell] Missing module directory: $_QUINLAN_MODULE_ROOT" >&2
    echo "[quinlan-shell] Run: chezmoi apply --force" >&2
else
    _quinlan_source_module "path.sh"
    _quinlan_source_module "auto-env.sh"
    _quinlan_source_module "claude.sh"
    _quinlan_source_module "azure.sh"
fi

if [[ ! -f "$_QUINLAN_USER_FILE" ]]; then
    echo "[quinlan-shell] Missing role file: $_QUINLAN_USER_FILE" >&2
    echo "[quinlan-shell] Set it to 'timon' or 'jeremy' (usually done by /update)." >&2
else
    QUINLAN_USER="$(tr -d '[:space:]' < "$_QUINLAN_USER_FILE" | tr '[:upper:]' '[:lower:]')"
    export QUINLAN_USER

    case "$QUINLAN_USER" in
        timon)
            _quinlan_source_module "codex-wsl.sh"
            ;;
        jeremy)
            # Jeremy only needs the shared base modules and cc alias.
            ;;
        *)
            echo "[quinlan-shell] Invalid role '${QUINLAN_USER}' in $_QUINLAN_USER_FILE" >&2
            echo "[quinlan-shell] Expected 'timon' or 'jeremy'." >&2
            ;;
    esac
fi

if [[ -d "$_QUINLAN_MODULE_ROOT" ]]; then
    _quinlan_source_module "local.sh"
fi

unset -f _quinlan_source_module
unset _QUINLAN_MODULE_ROOT
unset _QUINLAN_USER_FILE
